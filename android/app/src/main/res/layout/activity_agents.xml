<?xml version="1.0" encoding="utf-8"?>
<!--
  Agents — text-first. Crumb header, eyebrow-driven sections, hard-edged list.
  Widget IDs: agentsRecycler, emptyState, createAgentFab, bottomNav.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Crumb header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="40dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ghola"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  /  "
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="agents"
                android:textColor="#eef1f8"
                android:textSize="14sp"
                android:fontFamily="@font/geist"
                android:textFontWeight="500" />
            <!-- inline + button in header instead of FAB -->
            <TextView
                android:id="@+id/createInlineButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ NEW"
                android:textColor="#3da8ff"
                android:textSize="11sp"
                android:textFontWeight="500"
                android:letterSpacing="0.12"
                android:fontFamily="@font/geist"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/agentsRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="96dp" />

            <!-- Empty state — typographic, not a card -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="64dp"
                android:visibility="gone">

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="› EMPTY"
                    android:layout_marginBottom="12dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No agents."
                    android:textColor="#eef1f8"
                    android:textSize="32sp"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500"
                    android:letterSpacing="-0.03"
                    android:includeFontPadding="false"
                    android:layout_marginBottom="16dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create an agent. It gets a cryptographic identity, a Solana wallet, and can transact on your behalf."
                    android:textColor="#8b95a8"
                    android:textSize="15sp"
                    android:fontFamily="@font/geist"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="40dp" />

                <!-- Primary action — hard-edged, no rounded corners -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createAgentFab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE AGENT"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#3da8ff"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
