<?xml version="1.0" encoding="utf-8"?>
<!--
  Agent Detail — text-first, crumb header "ghola / agents / [slug]", eyebrow sections,
  no cards. Mono for DIDs and addresses. Stats as large inline numbers, not a grid of cards.
  Widget IDs: displayName, slug, bio, did, solanaAddress, balance, reputation, serviceCount, earned, loading.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipToPadding="false"
    android:paddingTop="24dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Crumb header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="48dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ghola"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  /  "
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono" />
            <TextView
                android:id="@+id/crumbAgents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="agents"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  /  "
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono" />
            <TextView
                android:id="@+id/slug"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="#eef1f8"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Display name: hero -->
        <TextView
            android:id="@+id/displayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eef1f8"
            android:textSize="40sp"
            android:fontFamily="@font/geist"
            android:textFontWeight="500"
            android:letterSpacing="-0.03"
            android:includeFontPadding="false"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/bio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#8b95a8"
            android:textSize="15sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="56dp"
            android:visibility="gone" />

        <!-- BALANCE — hero number -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› BALANCE"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textColor="#eef1f8"
                android:textSize="56sp"
                android:fontFamily="@font/geist"
                android:letterSpacing="-0.03"
                android:includeFontPadding="false" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" USDC"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="#3da8ff"
            android:layout_marginBottom="56dp" />

        <!-- IDENTITY -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› IDENTITY"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="did"
            android:textColor="#4a5568"
            android:textSize="11sp"
            android:fontFamily="@font/geist_mono"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/did"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eef1f8"
            android:textSize="13sp"
            android:fontFamily="@font/geist_mono"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="solana"
            android:textColor="#4a5568"
            android:textSize="11sp"
            android:fontFamily="@font/geist_mono"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/solanaAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eef1f8"
            android:textSize="13sp"
            android:fontFamily="@font/geist_mono"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="56dp" />

        <!-- REPUTATION / SERVICES / EARNED — inline text stats -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› STATS"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="56dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="rep"
                    android:textColor="#4a5568"
                    android:textSize="11sp"
                    android:fontFamily="@font/geist_mono"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/reputation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#eef1f8"
                    android:textSize="32sp"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.02"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="services"
                    android:textColor="#4a5568"
                    android:textSize="11sp"
                    android:fontFamily="@font/geist_mono"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/serviceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#eef1f8"
                    android:textSize="32sp"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.02"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="earned"
                    android:textColor="#4a5568"
                    android:textSize="11sp"
                    android:fontFamily="@font/geist_mono"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/earned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textColor="#eef1f8"
                    android:textSize="32sp"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.02"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#3da8ff"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
