<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared list row for the Agents list and the Activity feed. Polished surface
  card matching the Home/Markets design system (rounded, bordered, ghola tokens).
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/ghola_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ghola_border"
    app:strokeWidth="1dp"
    app:rippleColor="@color/ghola_accent_wash"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="15dp"
        android:paddingEnd="16dp"
        android:paddingBottom="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/cardDisplayName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:textSize="16sp"
                android:textColor="@color/ghola_text_primary"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/cardStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/geist_mono"
                android:text="active"
                android:textSize="12sp"
                android:textColor="@color/ghola_success" />
        </LinearLayout>

        <TextView
            android:id="@+id/cardSlug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/geist"
            android:textSize="13sp"
            android:textColor="@color/ghola_text_secondary" />

        <TextView
            android:id="@+id/cardBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:fontFamily="@font/geist"
            android:textSize="13sp"
            android:textColor="@color/ghola_text_secondary"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/cardDid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:fontFamily="@font/geist_mono"
            android:textSize="11sp"
            android:textColor="@color/ghola_text_tertiary"
            android:ellipsize="middle"
            android:singleLine="true" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
