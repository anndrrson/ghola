# Copy to deploy/private-agent-pooled-credentials.env and replace every value.
# Do not commit the real file. It is gitignored.

# Hyperliquid pooled account pool.
# account_address is the funded mainnet account. api_wallet_private_key is a scoped Hyperliquid API wallet key.
PRIVATE_AGENT_HYPERLIQUID_MANAGED_ACCOUNTS_JSON='{"accounts":[{"network":"mainnet","account_address":"0xREPLACE_WITH_40_HEX_CHARS","api_wallet_private_key":"0xREPLACE_WITH_64_HEX_CHARS"}]}'

# Phoenix pooled authority.
# wallet_private_key may be a Solana secret-key byte array or the worker-supported secret format.
PRIVATE_AGENT_SOLANA_PERPS_POOLED_VAULT_JSON='{"kind":"ghola_solana_perps_execution_vault","network":"mainnet","wallet_private_key":[0]}'

# Jupiter pooled authority and API key.
PRIVATE_AGENT_JUPITER_POOLED_VAULT_JSON='{"kind":"ghola_solana_swap_execution_vault","network":"mainnet","wallet_private_key":[0]}'
PRIVATE_AGENT_JUPITER_API_KEY='REPLACE_WITH_JUPITER_API_KEY'

# Coinbase omnibus pool.
# Keep PEM newlines escaped as \n, or provide PRIVATE_AGENT_COINBASE_PARTNER_POOL_VAULT_JSON_B64 instead.
PRIVATE_AGENT_COINBASE_PARTNER_POOL_VAULT_JSON='{"kind":"ghola_coinbase_advanced_execution_vault","network":"mainnet","api_key_name":"REPLACE_WITH_COINBASE_API_KEY_NAME","api_private_key_pem":"-----BEGIN EC PRIVATE KEY-----\nREPLACE_WITH_COINBASE_PRIVATE_KEY\n-----END EC PRIVATE KEY-----","portfolio_id":"REPLACE_WITH_PORTFOLIO_ID_IF_REQUIRED"}'
