<?xml version="1.0" encoding="utf-8"?>
<!--
  Home hero plate. Rounded, with a subtle top-lit gradient that lifts the
  command-center block off the pure-black background, plus a hairline border
  in the Ghola line language.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="22dp" />
    <gradient
        android:angle="270"
        android:startColor="@color/ghola_card_top"
        android:endColor="@color/ghola_card_bottom" />
    <stroke android:width="1dp" android:color="@color/ghola_border" />
</shape>
