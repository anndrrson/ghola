<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:paddingTop="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp">

            <TextView
                android:id="@+id/crumbMessages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="messages"
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist_mono" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="new"
                    android:textColor="#eef1f8"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist"
                android:textFontWeight="500" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New message"
                android:textColor="#eef1f8"
                android:textSize="38sp"
                android:textFontWeight="500"
                android:fontFamily="@font/geist"
                android:includeFontPadding="false"
                android:layout_marginBottom="46dp" />

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› TO"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/recipientInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textColor="#eef1f8"
                android:textColorHint="#4a5568"
                android:textSize="20sp"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:hint="Name or wallet"
                android:inputType="text"
                android:singleLine="true"
                android:padding="0dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/recipientModeLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#3da8ff"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:fontFamily="@font/geist_mono"
                android:visibility="gone"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/recipientStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4a5568"
                android:textSize="12sp"
                android:fontFamily="@font/geist"
                android:visibility="gone"
                android:layout_marginBottom="34dp" />

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› MESSAGE"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:background="@null"
                android:gravity="top"
                android:textColor="#eef1f8"
                android:textColorHint="#4a5568"
                android:textSize="20sp"
                android:fontFamily="@font/geist"
                android:hint="Write a message"
                android:inputType="textMultiLine|textCapSentences"
                android:padding="0dp"
                android:layout_marginBottom="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startMessageButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="START MESSAGE"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inviteFromComposeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="INVITE SOMEONE"
                android:textColor="#8b95a8"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#111827"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <TextView
                android:id="@+id/composeStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4a5568"
                android:textSize="13sp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:visibility="gone" />

            <TextView
                android:id="@+id/peopleHeader"
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› PEOPLE"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/peopleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
