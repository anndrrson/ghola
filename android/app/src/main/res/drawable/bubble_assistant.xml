<?xml version="1.0" encoding="utf-8"?>
<!--
  Assistant message bubble — elevated surface with a hairline border. Matches
  the home command-card treatment so chat feels like a continuation of the
  home grid, not a detour.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ghola_surface" />
    <stroke android:width="1dp" android:color="@color/ghola_border" />
</shape>
