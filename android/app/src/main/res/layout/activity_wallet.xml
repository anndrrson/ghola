<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="ghola"
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist_mono"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="@string/wallet_nav_title"
                    android:textColor="#eef1f8"
                    android:textFontWeight="500"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/wallet_primary_section_title" />

            <TextView
                android:id="@+id/deviceType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/geist"
                android:includeFontPadding="false"
                android:textColor="#eef1f8"
                android:textFontWeight="500"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/seedVaultStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:textColor="#8b95a8"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectWalletButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/wallet_connect_button"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disconnectWalletButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="SIGN OUT"
                android:textColor="#8b95a8"
                android:textFontWeight="500"
                android:textSize="12sp"
                android:visibility="gone"
                app:backgroundTint="#111827"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <TextView
                android:id="@+id/connectStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:textColor="#8b95a8"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/connectedPubkey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="44dp"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.25"
                android:textColor="#3da8ff"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#1e2a3a" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/advancedWalletButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="ADVANCED"
                android:textColor="#8b95a8"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#111827"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <LinearLayout
                android:id="@+id/advancedWalletSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="› DEVICE" />

                <TextView
                    android:id="@+id/walletPackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/geist_mono"
                    android:textColor="#8b95a8"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/wallet_proof_section_title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/verifySeekerButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.12"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/wallet_verify_button"
                    android:textColor="#8b95a8"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />

                <TextView
                    android:id="@+id/seekerVerificationStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:text="not verified"
                    android:textColor="#8b95a8"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="› PRIVATE PAYMENTS" />

                <TextView
                    android:id="@+id/privateRailStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="#8b95a8"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/privateSelfTestButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.12"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="RUN REAL LOCAL PROOF"
                    android:textColor="#8b95a8"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />

                <EditText
                    android:id="@+id/privateRecipientInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/geist_mono"
                    android:hint="Solana shielded recipient"
                    android:inputType="textNoSuggestions"
                    android:maxLines="3"
                    android:minLines="1"
                    android:singleLine="false"
                    android:textColor="#eef1f8"
                    android:textColorHint="#4a5568"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/privateAmountInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:hint="Amount USDCx"
                    android:inputType="numberDecimal"
                    android:textColor="#eef1f8"
                    android:textColorHint="#4a5568"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createPrivateIntentButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.12"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="APPROVE PRIVATE PAYMENT"
                    android:textColor="#8b95a8"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />

                <TextView
                    android:id="@+id/privateIntentStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="#8b95a8"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/privateHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="#8b95a8"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/walletStatus"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agentCount"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
