<?xml version="1.0" encoding="utf-8"?>
<!--
  Wallet — no cards. Text-first, hard left-aligned, Linear/Arc settings style.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:paddingTop="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Crumb header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ghola"
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist_mono" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="wallet"
                    android:textColor="#eef1f8"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500" />
            </LinearLayout>

            <TextView
                android:id="@+id/walletStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet status"
                android:textColor="#8b95a8"
                android:textSize="15sp"
                android:fontFamily="@font/geist"
                android:visibility="gone" />

            <!-- DEVICE -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› DEVICE"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/deviceType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="#eef1f8"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/seedVaultStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#8b95a8"
                android:fontFamily="@font/geist"
                android:layout_marginBottom="56dp" />

            <!-- CONNECT — live MWA authorize flow -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› CONNECT"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectWalletButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT SEED VAULT  →"
                android:textColor="#000000"
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <TextView
                android:id="@+id/connectStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="13sp"
                android:textColor="#8b95a8"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.3"
                android:text="" />

            <TextView
                android:id="@+id/connectedPubkey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="56dp"
                android:textSize="13sp"
                android:textColor="#3da8ff"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.3"
                android:text="" />

            <!-- DETECTED -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› DETECTED"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/walletPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#eef1f8"
                android:fontFamily="@font/geist_mono"
                android:layout_marginBottom="56dp" />

            <!-- YOUR AGENTS -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› YOUR AGENTS"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/agentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="56sp"
                android:textColor="#eef1f8"
                android:fontFamily="@font/geist"
                android:letterSpacing="-0.03"
                android:includeFontPadding="false"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Each agent has its own isolated wallet, scoped to a single task or relationship."
                android:textSize="13sp"
                android:textColor="#8b95a8"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
