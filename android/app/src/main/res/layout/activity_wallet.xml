<?xml version="1.0" encoding="utf-8"?>
<!--
  Wallet — Seeker/MWA sign-in surface in the polished Home/Markets design.
  IDs preserved: deviceType, walletCapabilityStatus, connectWalletButton,
  disconnectWalletButton, connectStatus, connectedPubkey, advancedWalletButton,
  advancedWalletSection, walletPackage, verifySeekerButton,
  seekerVerificationStatus, privateRailStatus, privateSelfTestButton,
  privateRecipientInput, privateAmountInput, createPrivateIntentButton,
  privateIntentStatus, privateHistory, walletStatus, agentCount, bottomNav.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghola_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="120dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.01"
                    android:text="@string/wallet_nav_title"
                    android:textColor="@color/ghola_text_primary"
                    android:textFontWeight="600"
                    android:textSize="23sp" />
            </LinearLayout>

            <!-- Dynamic device label ("Seeker Wallet" / "Wallet") as the eyebrow,
                 set by WalletActivity.render(). Avoids repeating the top-bar title. -->
            <TextView
                android:id="@+id/deviceType"
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/walletCapabilityStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:textColor="@color/ghola_text_secondary"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectWalletButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/wallet_connect_button"
                android:textAllCaps="false"
                android:textColor="@color/ghola_cta_ink"
                android:textFontWeight="600"
                android:textSize="16sp"
                app:backgroundTint="@color/ghola_accent"
                app:cornerRadius="16dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disconnectWalletButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Sign out"
                android:textAllCaps="false"
                android:textColor="@color/ghola_text_secondary"
                android:textFontWeight="500"
                android:textSize="15sp"
                android:visibility="gone"
                app:backgroundTint="@color/ghola_chip_bg"
                app:cornerRadius="13dp"
                app:elevation="0dp"
                app:rippleColor="@color/ghola_accent_wash"
                app:strokeColor="@color/ghola_border"
                app:strokeWidth="1dp" />

            <TextView
                android:id="@+id/connectStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:textColor="@color/ghola_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/connectedPubkey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="36dp"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.25"
                android:textColor="@color/ghola_accent"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="@color/ghola_border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/advancedWalletButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Advanced"
                android:textAllCaps="false"
                android:textColor="@color/ghola_text_secondary"
                android:textFontWeight="500"
                android:textSize="15sp"
                app:backgroundTint="@color/ghola_chip_bg"
                app:cornerRadius="13dp"
                app:elevation="0dp"
                app:rippleColor="@color/ghola_accent_wash"
                app:strokeColor="@color/ghola_border"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:id="@+id/advancedWalletSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Device" />

                <TextView
                    android:id="@+id/walletPackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/geist_mono"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/wallet_proof_section_title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/verifySeekerButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/wallet_verify_button"
                    android:textAllCaps="false"
                    android:textColor="@color/ghola_text_secondary"
                    android:textFontWeight="500"
                    android:textSize="15sp"
                    app:backgroundTint="@color/ghola_chip_bg"
                    app:cornerRadius="13dp"
                    app:elevation="0dp"
                    app:rippleColor="@color/ghola_accent_wash"
                    app:strokeColor="@color/ghola_border"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/seekerVerificationStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:text="not verified"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Private payments" />

                <TextView
                    android:id="@+id/privateRailStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/privateSelfTestButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Run real local proof"
                    android:textAllCaps="false"
                    android:textColor="@color/ghola_text_secondary"
                    android:textFontWeight="500"
                    android:textSize="15sp"
                    app:backgroundTint="@color/ghola_chip_bg"
                    app:cornerRadius="13dp"
                    app:elevation="0dp"
                    app:rippleColor="@color/ghola_accent_wash"
                    app:strokeColor="@color/ghola_border"
                    app:strokeWidth="1dp" />

                <EditText
                    android:id="@+id/privateRecipientInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/geist_mono"
                    android:hint="Solana shielded recipient"
                    android:inputType="textNoSuggestions"
                    android:maxLines="3"
                    android:minLines="1"
                    android:singleLine="false"
                    android:textColor="@color/ghola_text_primary"
                    android:textColorHint="@color/ghola_text_tertiary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/privateAmountInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:hint="Amount USDCx"
                    android:inputType="numberDecimal"
                    android:textColor="@color/ghola_text_primary"
                    android:textColorHint="@color/ghola_text_tertiary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createPrivateIntentButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Approve private payment"
                    android:textAllCaps="false"
                    android:textColor="@color/ghola_text_secondary"
                    android:textFontWeight="500"
                    android:textSize="15sp"
                    app:backgroundTint="@color/ghola_chip_bg"
                    app:cornerRadius="13dp"
                    app:elevation="0dp"
                    app:rippleColor="@color/ghola_accent_wash"
                    app:strokeColor="@color/ghola_border"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/privateIntentStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/privateHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/walletStatus"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agentCount"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/ghola_bg"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="@color/ghola_border" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
