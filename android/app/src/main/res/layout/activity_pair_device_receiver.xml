<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="ghola"
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist_mono"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="messages"
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist_mono"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="receive"
                    android:textColor="#eef1f8"
                    android:textFontWeight="500"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="› NEW PHONE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/geist"
                android:includeFontPadding="false"
                android:text="Receive chats here"
                android:textColor="#eef1f8"
                android:textFontWeight="500"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/pairReceiverStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:text="This phone will wait for your old phone to send its encrypted chats."
                android:textColor="#8b95a8"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createPairCodeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="CREATE RECEIVE CODE"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <FrameLayout
                android:id="@+id/pairQrFrame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="#eef1f8"
                android:padding="18dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/pairQrImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="Receive code QR" />
            </FrameLayout>

            <TextView
                android:id="@+id/pairCodeLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#0f1117"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.25"
                android:padding="16dp"
                android:textColor="#8b95a8"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sharePairCodeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="SEND CODE TO OLD PHONE"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                android:visibility="gone"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <LinearLayout
                android:id="@+id/pairCodeActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyPairCodeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.12"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="COPY CODE"
                    android:textColor="#8b95a8"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/showPairQrButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.12"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="SHOW QR"
                    android:textColor="#8b95a8"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/pairReceiverHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:text="On the phone that already has your chats, open Messages > Send Chats, then paste this code. Keep this screen open." />
                android:textColor="#4a5568"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
