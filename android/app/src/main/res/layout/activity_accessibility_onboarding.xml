<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility onboarding — text-first, avant-garde, one-tap path to
  granting Ghola's accessibility permission. Crumb header, huge display
  type explaining WHY, three eyebrow-labelled reassurances, one hard-
  edged blue CTA. Matches the rest of the app's Linear/Arc aesthetic.

  Widget IDs:
    crumbBack, grantButton, statusBadge
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipToPadding="false"
    android:paddingTop="24dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Crumb header: ghola / setup / accessibility -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="56dp">
            <TextView
                android:id="@+id/crumbBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ghola"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  /  "
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="setup"
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  /  "
                android:textColor="#4a5568"
                android:textSize="14sp"
                android:fontFamily="@font/geist_mono" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="accessibility"
                android:textColor="#eef1f8"
                android:textSize="14sp"
                android:fontFamily="@font/geist"
                android:textFontWeight="500" />
            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› NOT GRANTED"
                android:textColor="#ef4444"
                android:textSize="11sp"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <!-- Eyebrow + hero title -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› ONE MORE THING"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The AI that uses your apps."
            android:textColor="#eef1f8"
            android:textSize="40sp"
            android:fontFamily="@font/geist"
            android:textFontWeight="500"
            android:letterSpacing="-0.03"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.05"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To tap buttons, type text, and open things on your behalf, Ghola needs Android's Accessibility permission — the same API a screen reader uses."
            android:textColor="#8b95a8"
            android:textSize="16sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.45"
            android:layout_marginBottom="56dp" />

        <!-- Three reassurances — eyebrow / body pairs -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› ON DEVICE"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actions execute locally. Your screen is never recorded or streamed anywhere."
            android:textColor="#eef1f8"
            android:textSize="15sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp" />

        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› HARDWARE-BACKED"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agent keys live in the Seeker's Seed Vault — the secure element inside your phone."
            android:textColor="#eef1f8"
            android:textSize="15sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp" />

        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› REVOCABLE"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn Ghola off at any time in Android Settings → Accessibility. Nothing persists once it's revoked."
            android:textColor="#eef1f8"
            android:textSize="15sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="56dp" />

        <!-- Explicit step-by-step guide. On most custom Android ROMs (Samsung,
             Seeker, etc.) the deep link lands on a LIST of accessibility services
             instead of jumping straight to Ghola. That's where users previously
             tapped TalkBack by mistake. This copy names the correct row and
             explicitly warns against the wrong one. -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› TAP THIS ROW"
            android:layout_marginBottom="12dp" />

        <!-- Visual mockup: an annotated replica of the exact Android list item
             the user is hunting for. Blue left border, Ghola icon on the
             left, name + status in geist. Users see what to look for BEFORE
             they see the real settings list, so the "which one is Ghola"
             question gets answered upfront. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0b0e14"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ghola"
                    android:textColor="#eef1f8"
                    android:textSize="17sp"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="#8b95a8"
                    android:textSize="13sp"
                    android:fontFamily="@font/geist"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:layout_width="44dp"
                android:layout_height="24dp"
                android:background="#1e2a3a" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ←"
                android:textColor="#3da8ff"
                android:textSize="22sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is what you're looking for. Blue robot icon. Name says &quot;Ghola&quot;."
            android:textColor="#8b95a8"
            android:textSize="12sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.35"
            android:layout_marginBottom="32dp" />

        <!-- Anti-pattern mockup: what NOT to tap. Greyed out with a red X to
             make it visually obvious that this is the "don't tap" row. -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› NOT THIS ONE"
            android:textColor="#ef4444"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0b0e14"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:alpha="0.45"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#374151"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TalkBack"
                    android:textColor="#eef1f8"
                    android:textSize="17sp"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="#8b95a8"
                    android:textSize="13sp"
                    android:fontFamily="@font/geist"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×"
                android:textColor="#ef4444"
                android:textSize="28sp"
                android:textFontWeight="600" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TalkBack is Google&apos;s screen reader. Turning it on makes your phone read everything aloud and lag heavily. Skip it."
            android:textColor="#8b95a8"
            android:textSize="12sp"
            android:fontFamily="@font/geist"
            android:lineSpacingMultiplier="1.35"
            android:layout_marginBottom="40dp" />

        <!-- Numbered textual guide as a reinforcement of the visual -->
        <TextView
            style="@style/Ghola.Text.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="› THE SEQUENCE"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Android opens the Accessibility settings.\n2. Scroll down to Installed apps.\n3. Tap Ghola (blue robot icon).\n4. Flip the switch to ON.\n5. Tap Allow on the dialog.\n6. Press back. Ghola detects the change."
            android:textColor="#eef1f8"
            android:textSize="14sp"
            android:fontFamily="@font/geist_mono"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="20dp" />

        <!-- Red warning panel — do NOT tap TalkBack -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a0a0a"
            android:padding="16dp"
            android:layout_marginBottom="32dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› IMPORTANT"
                android:textColor="#ef4444"
                android:textSize="11sp"
                android:fontFamily="@font/geist"
                android:textFontWeight="500"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DO NOT tap TalkBack, Select to Speak, or Voice Access. Those are Google&apos;s screen readers — if you enable them by mistake your phone will start announcing every tap and become unusable. Tap GHOLA only."
                android:textColor="#fca5a5"
                android:textSize="13sp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Primary CTA — hard-edged, oversized -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/grantButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GRANT PERMISSION  →"
            android:textColor="#000000"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:fontFamily="@font/geist"
            android:textFontWeight="500"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#3da8ff"
            app:cornerRadius="0dp"
            app:elevation="0dp" />

        <TextView
            android:id="@+id/skipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip for now"
            android:textColor="#4a5568"
            android:textSize="13sp"
            android:fontFamily="@font/geist"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>
</ScrollView>
