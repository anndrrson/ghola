<?xml version="1.0" encoding="utf-8"?>
<!--
  Messages — native relay inbox for wallet-bound device sessions, in the
  polished Home/Markets design. Widget IDs: messageStatusTitle,
  messageStatusBody, messageWalletLine, newMessageButton, copyInviteButton,
  refreshInboxButton, inboxContainer, bottomNav.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghola_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="120dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.01"
                    android:text="@string/messages_title"
                    android:textColor="@color/ghola_text_primary"
                    android:textFontWeight="600"
                    android:textSize="23sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/messageStatusTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/geist"
                android:textColor="@color/ghola_text_primary"
                android:textFontWeight="500"
                android:textSize="16sp"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/messageStatusBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:textColor="@color/ghola_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/messageWalletLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.25"
                android:textColor="@color/ghola_accent"
                android:textSize="13sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newMessageButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/messages_new"
                android:textAllCaps="false"
                android:textColor="@color/ghola_cta_ink"
                android:textFontWeight="600"
                android:textSize="16sp"
                app:backgroundTint="@color/ghola_accent"
                app:cornerRadius="16dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/copyInviteButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/messages_copy_invite"
                android:textAllCaps="false"
                android:textColor="@color/ghola_text_secondary"
                android:textFontWeight="500"
                android:textSize="15sp"
                app:backgroundTint="@color/ghola_chip_bg"
                app:cornerRadius="13dp"
                app:elevation="0dp"
                app:rippleColor="@color/ghola_accent_wash"
                app:strokeColor="@color/ghola_border"
                app:strokeWidth="1dp" />

            <!-- Recent header + refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/messages_recent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refreshInboxButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:fontFamily="@font/geist"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/messages_refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/ghola_text_secondary"
                    android:textFontWeight="500"
                    android:textSize="13sp"
                    app:backgroundTint="@color/ghola_chip_bg"
                    app:cornerRadius="13dp"
                    app:elevation="0dp"
                    app:rippleColor="@color/ghola_accent_wash"
                    app:strokeColor="@color/ghola_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/inboxContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="@color/ghola_border" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/ghola_bg"
        app:elevation="0dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
