<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#000000" app:strokeColor="#1e2a3a" app:strokeWidth="1dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/cardDisplayName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#eef1f8" />

            <TextView
                android:id="@+id/cardStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="active"
                android:textSize="11sp"
                android:textColor="#34d399"
                android:padding="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/cardSlug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#8b95a8"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/cardBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#8b95a8"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/cardDid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#8b95a8"
            android:fontFamily="@font/geist_mono"
            android:ellipsize="middle"
            android:singleLine="true"
            android:layout_marginTop="12dp" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
