<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase α build unblocker.

    The settings sheets (sheet_settings_*.xml) and BYOM layouts under res/layout
    landed as untracked WIP without the matching style definitions in
    res/values. Without these stubs the Android resource linker (aapt2) fails,
    which blocks every Kotlin compile task (because they depend on R.jar) —
    including unit-test compilation of the new BatteryEnergyProfiler /
    ThermalStateProvider added in Phase α.

    These styles are intentionally minimal — they only need to satisfy aapt's
    resolution pass. The actual visual styling will be filled in by the
    parallel settings UI effort. Do not delete: the Phase α tests rely on
    compileDebugKotlin succeeding.
-->
<resources>
    <style name="Ghola.Settings.Card" parent="android:Widget" />
    <style name="Ghola.Settings.CardRow" parent="android:Widget" />
    <style name="Ghola.Settings.CardText" parent="android:Widget" />
    <style name="Ghola.Settings.Title" parent="android:TextAppearance" />
    <style name="Ghola.Settings.Subtitle" parent="android:TextAppearance" />
    <style name="Ghola.Settings.Chevron" parent="android:Widget" />

    <style name="Ghola.Byom.Toggle" parent="android:Widget" />

    <style name="Ghola.SecondaryButton" parent="android:Widget" />
    <style name="Ghola.DestructiveButton" parent="android:Widget" />
</resources>
