{
  "address": "7hZ9oxHyFRpKHtH3jsa8NeH4HYGrPT7ZttDFtUX9naNS",
  "metadata": {
    "name": "ghola_model_registry",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "Ghola on-chain model registry — content-addressed open-weight model metadata"
  },
  "instructions": [
    {
      "name": "register_model",
      "docs": [
        "Register a new model. The signer becomes the entry's creator",
        "and is the only key that can update the entry afterwards.",
        "Fails if the entry already exists (Anchor's `init` does the",
        "uniqueness enforcement via the PDA seed collision)."
      ],
      "discriminator": [
        111,
        236,
        93,
        31,
        195,
        210,
        142,
        125
      ],
      "accounts": [
        {
          "name": "model",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [
                  103,
                  104,
                  111,
                  108,
                  97,
                  45,
                  109,
                  111,
                  100,
                  101,
                  108
                ]
              },
              {
                "kind": "arg",
                "path": "model_id_hash"
              }
            ]
          }
        },
        {
          "name": "creator",
          "writable": true,
          "signer": true
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": [
        {
          "name": "model_id_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "model_id",
          "type": "string"
        },
        {
          "name": "weights_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "model_lib_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "config_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "tokenizer_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "ipfs_cid",
          "type": "string"
        },
        {
          "name": "license_spdx",
          "type": "string"
        },
        {
          "name": "price_micro_usdc",
          "type": "u64"
        }
      ]
    },
    {
      "name": "update_model",
      "docs": [
        "Update fields that can drift over a model's lifetime (license",
        "terms, pricing, new IPFS pin location). Hash fields are",
        "**immutable** — content-addressed records must not allow the",
        "creator to retroactively swap weights under the same model id."
      ],
      "discriminator": [
        76,
        230,
        44,
        16,
        103,
        83,
        24,
        73
      ],
      "accounts": [
        {
          "name": "model",
          "writable": true
        },
        {
          "name": "creator",
          "signer": true,
          "relations": [
            "model"
          ]
        }
      ],
      "args": [
        {
          "name": "ipfs_cid",
          "type": "string"
        },
        {
          "name": "license_spdx",
          "type": "string"
        },
        {
          "name": "price_micro_usdc",
          "type": "u64"
        }
      ]
    }
  ],
