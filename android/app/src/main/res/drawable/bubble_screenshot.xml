<?xml version="1.0" encoding="utf-8"?>
<!--
  Screenshot frame — surface-elevated with a thin border. Matches the chat
  card vocabulary so embedded screen-grabs don't look like a paste-bin.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/ghola_surface_elevated" />
    <stroke android:width="1dp" android:color="@color/ghola_border" />
</shape>
