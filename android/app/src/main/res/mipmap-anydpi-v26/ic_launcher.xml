<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon for Android 8+ (API 26+).
  Background: solid dark panel matching ghola.xyz (#08090d).
  Foreground: the ghola robot figure vector.
  Monopoly-shape masking, parallax, and tinting are applied by the launcher.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
