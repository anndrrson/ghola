# said-receipts-service image for the e2e stack.
FROM rust:1.79-slim-bookworm AS builder

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY mcp-server/ mcp-server/
COPY cli/ cli/
COPY daemon/ daemon/
COPY integration-tests/ integration-tests/
COPY migrations/ migrations/
COPY migrations-receipts/ migrations-receipts/
COPY programs/ programs/
COPY apps/ apps/
COPY packages/ packages/

RUN cargo build --release -p said-receipts-service

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/said-receipts-service /usr/local/bin/said-receipts-service
COPY migrations-receipts/ /opt/migrations/

ENV PORT=8088
EXPOSE 8088
CMD ["said-receipts-service"]
