<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghola_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top bar ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/geist"
                    android:letterSpacing="-0.01"
                    android:text="ghola"
                    android:textColor="@color/ghola_text_primary"
                    android:textFontWeight="600"
                    android:textSize="23sp" />

                <ImageButton
                    android:id="@+id/profileButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Settings"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_thin"
                    app:tint="@color/ghola_text_secondary" />
            </LinearLayout>

            <!-- Legacy greeting holder kept for HomeActivity bindings. -->
            <TextView
                android:id="@+id/greetingText"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- ── Hero command card ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_hero_card"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <!-- Status pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_status"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="6dp">

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_dot_success" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/geist"
                        android:letterSpacing="0.02"
                        android:text="@string/home_status_ready"
                        android:textColor="@color/ghola_success"
                        android:textFontWeight="500"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/geist"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.02"
                    android:text="@string/home_hero_title"
                    android:textColor="@color/ghola_text_primary"
                    android:textFontWeight="600"
                    android:textSize="31sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:fontFamily="@font/geist"
                    android:lineSpacingMultiplier="1.25"
                    android:text="@string/home_hero_body"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="15sp" />

                <!-- Wallet chip -->
                <TextView
                    android:id="@+id/homeWalletButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_wallet_chip"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/geist_mono"
                    android:gravity="center_vertical"
                    android:minHeight="50dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="WALLET"
                    android:textColor="@color/ghola_text_secondary"
                    android:textFontWeight="500"
                    android:textSize="12sp"
                    app:drawableStartCompat="@drawable/ic_solana_glyph" />

                <!-- Primary CTA -->
                <LinearLayout
                    android:id="@+id/launchTerminalButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_primary_cta"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/geist"
                        android:letterSpacing="-0.01"
                        android:text="@string/home_launch_terminal"
                        android:textColor="@color/ghola_cta_ink"
                        android:textFontWeight="600"
                        android:textSize="17sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="9dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/ghola_cta_ink" />
                </LinearLayout>
            </LinearLayout>

            <!-- Voice orb — only shown when voice input is enabled; gone otherwise. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/micOrbContainer"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_wallet_chip"
                    android:visibility="gone">

                    <ImageButton
                        android:id="@+id/micFab"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackground"
                        android:contentDescription="Ask Ghola by voice"
                        android:padding="15dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_mic_thin"
                        app:tint="@color/ghola_accent" />
                </FrameLayout>
            </LinearLayout>

            <!-- ── Quick actions ──────────────────────────────────── -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="12dp"
                android:text="@string/home_desk_label" />

            <FrameLayout
                android:id="@+id/quickActionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionCall"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/ghola_surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:rippleColor="@color/ghola_accent_wash"
                        app:strokeColor="@color/ghola_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_plate">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:importantForAccessibility="no"
                                    android:src="@drawable/ic_nav_wallet"
                                    app:tint="@color/ghola_accent" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginTop="11dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_wallet_label"
                                android:textColor="@color/ghola_text_primary"
                                android:textFontWeight="500"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_wallet_desc"
                                android:textColor="@color/ghola_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionDevice"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/ghola_surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:rippleColor="@color/ghola_accent_wash"
                        app:strokeColor="@color/ghola_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_plate">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:importantForAccessibility="no"
                                    android:src="@drawable/ic_nav_messages"
                                    app:tint="@color/ghola_accent" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginTop="11dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_messages_label"
                                android:textColor="@color/ghola_text_primary"
                                android:textFontWeight="500"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_messages_desc"
                                android:textColor="@color/ghola_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionChat"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/ghola_surface"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:rippleColor="@color/ghola_accent_wash"
                        app:strokeColor="@color/ghola_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_plate">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:importantForAccessibility="no"
                                    android:src="@drawable/ic_settings_thin"
                                    app:tint="@color/ghola_accent" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginTop="11dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_settings_label"
                                android:textColor="@color/ghola_text_primary"
                                android:textFontWeight="500"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/geist"
                                android:text="@string/home_tile_settings_desc"
                                android:textColor="@color/ghola_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </FrameLayout>

            <!-- ── Trust strip ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_pill_trust"
                android:gravity="center_vertical"
                android:minHeight="50dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="11dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_shield_check"
                    app:tint="@color/ghola_success" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="@string/home_trust"
                    android:textColor="@color/ghola_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ── Recent activity ────────────────────────────────── -->
            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="10dp"
                android:text="@string/home_active_label" />

            <LinearLayout
                android:id="@+id/activeTasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/voiceStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/geist_mono"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:textAlignment="center"
                android:textColor="@color/ghola_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="28dp" />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="@color/ghola_border" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/ghola_bg"
        app:elevation="0dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
