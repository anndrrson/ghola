<?xml version="1.0" encoding="utf-8"?>
<!-- Tappable wallet/address chip inside the hero. Accent ripple on press. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ghola_accent_wash">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <solid android:color="@color/ghola_chip_bg" />
            <stroke android:width="1dp" android:color="@color/ghola_border" />
        </shape>
    </item>
</ripple>
