<?xml version="1.0" encoding="utf-8"?>
<!--
  Ghola Android — Network Security Config (DEBUG overrides)

  This file only ships in debug builds (src/debug/res/xml/ overrides
  src/main/res/xml/ during merging). The release APK uses the strict
  policy at src/main/res/xml/network_security_config.xml.

  Debug-only relaxations:

    1. Localhost + RFC1918 LAN cleartext is permitted so the
       developer-LAN thumper-cloud (`http://192.168.1.169:3000` per
       app/build.gradle.kts debug block) and the legacy thumper-relay
       (`ws://192.168.1.100:8080/ws` per MainActivity default) keep
       working. Production users never hit these because the release
       build overrides the URL.

    2. `<debug-overrides>` block trusts user-installed CAs in addition
       to system CAs. This is what lets Charles Proxy / mitmproxy
       inspect HTTPS traffic for local debugging. The block is ONLY
       active for `debuggable=true` builds; it is a no-op in release.

  Everything else inherits from the strict release config — the same
  per-host allowlist below applies. If you add a new HTTPS host in
  Kotlin, add it to BOTH files (or factor out the shared list later).
-->
<network-security-config>

    <!-- Debug base config: still HTTPS-only by default. Localhost
         cleartext is permitted via the explicit domain-config below
         (more targeted than flipping the base-config bit). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Localhost + LAN dev hosts. Cleartext permitted so the
         developer's LAN-hosted thumper-cloud + thumper-relay are
         reachable from a Seeker on the same Wi-Fi. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- RFC1918 ranges can't be expressed as a single CIDR in
             network_security_config.xml, but the most common dev
             defaults from app/build.gradle.kts + MainActivity are
             listed individually. Override at build time if your dev
             machine sits on a different IP. -->
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.1.169</domain>
        <domain includeSubdomains="false">192.168.1.170</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- ghola.xyz: web origin + EmbedderClient static asset host. -->
    <domain-config>
        <domain includeSubdomains="true">ghola.xyz</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Render-hosted backends (SAID + thumper-cloud). -->
    <domain-config>
        <domain includeSubdomains="false">ghola-api.onrender.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <domain-config>
        <domain includeSubdomains="false">thumper-cloud.onrender.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Hugging Face (and its LFS CDN subdomains) — model downloads. -->
    <domain-config>
        <domain includeSubdomains="true">huggingface.co</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Cloud inference backends (Anthropic + Alibaba DashScope). -->
    <domain-config>
        <domain includeSubdomains="false">api.anthropic.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <domain-config>
        <domain includeSubdomains="false">dashscope-intl.aliyuncs.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Google OAuth + Gmail API + storage.googleapis.com (model bucket). -->
    <domain-config>
        <domain includeSubdomains="false">accounts.google.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    <domain-config>
        <domain includeSubdomains="true">googleapis.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Charles Proxy / mitmproxy hook: user-installed CAs only count
         when the app is debuggable=true. Release builds ignore this. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
