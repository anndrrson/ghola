<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="ghola"
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist_mono"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="messages"
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist_mono"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="send"
                    android:textColor="#eef1f8"
                    android:textFontWeight="500"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="› OLD PHONE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/geist"
                android:includeFontPadding="false"
                android:text="Send chats"
                android:textColor="#eef1f8"
                android:textFontWeight="500"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/pairSenderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:text="Paste the code from your new phone. Ghola will encrypt your chats and send them there."
                android:textColor="#8b95a8"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pastePairCodeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="PASTE CODE"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scanPairQrButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="SCAN QR INSTEAD"
                android:textColor="#8b95a8"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#111827"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <LinearLayout
                android:id="@+id/pairConfirmPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0f1117"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/geist"
                    android:text="Ready to send"
                    android:textColor="#eef1f8"
                    android:textFontWeight="500"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/receiverDidLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.2"
                    android:textColor="#8b95a8"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/walletDidLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/geist_mono"
                    android:lineSpacingMultiplier="1.2"
                    android:textColor="#8b95a8"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/confirmSendButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/geist"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0.12"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:text="SEND CHATS"
                        android:textColor="#000000"
                        android:textFontWeight="500"
                        android:textSize="12sp"
                        app:backgroundTint="#3da8ff"
                        app:cornerRadius="0dp"
                        app:elevation="0dp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cancelPairButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/geist"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0.12"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:text="CANCEL"
                        android:textColor="#8b95a8"
                        android:textFontWeight="500"
                        android:textSize="12sp"
                        app:backgroundTint="#111827"
                        app:cornerRadius="0dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
