<?xml version="1.0" encoding="utf-8"?>
<!--
  Messages — native relay inbox for wallet-bound device sessions.
  Keep security posture visible but not as raw debug output.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:paddingTop="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="56dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ghola"
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  /  "
                    android:textColor="#4a5568"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist_mono" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="messages"
                    android:textColor="#eef1f8"
                    android:textSize="14sp"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500" />
            </LinearLayout>

            <TextView
                style="@style/Ghola.Text.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="› INBOX"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/messageStatusTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textColor="#eef1f8"
                android:textSize="28sp"
                android:textFontWeight="500"
                android:fontFamily="@font/geist"
                android:includeFontPadding="false"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/messageStatusBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8b95a8"
                android:textSize="15sp"
                android:fontFamily="@font/geist"
                android:lineSpacingMultiplier="1.35"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/messageWalletLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#3da8ff"
                android:textSize="13sp"
                android:fontFamily="@font/geist_mono"
                android:lineSpacingMultiplier="1.25"
                android:layout_marginBottom="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newMessageButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="NEW MESSAGE"
                android:textColor="#000000"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#3da8ff"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/copyInviteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="44dp"
                android:fontFamily="@font/geist"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.12"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="COPY INVITE LINK"
                android:textColor="#8b95a8"
                android:textFontWeight="500"
                android:textSize="12sp"
                app:backgroundTint="#111827"
                app:cornerRadius="0dp"
                app:elevation="0dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    style="@style/Ghola.Text.Eyebrow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="› LATEST" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refreshInboxButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REFRESH"
                    android:textColor="#8b95a8"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="@font/geist"
                    android:textFontWeight="500"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#111827"
                    app:cornerRadius="0dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/inboxContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#000000"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:background="#1e2a3a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
